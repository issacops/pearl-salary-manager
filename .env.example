# Pearl Dental Payroll - Environment Variables
# Copy this file to .env.local and customize as needed

# Application Info
VITE_APP_NAME="Pearl Dental Payroll"
VITE_APP_VERSION="1.0.0"

# Optional: API URL for serverless backend (not required for localStorage mode)
VITE_API_URL=

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_REPORTING=false
